  },
  "dependencies": {
    "@supabase/supabase-js": "2.106.1",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "wrangler": "4.55.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
