{
  "name": "learning-journey-od",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.15",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
